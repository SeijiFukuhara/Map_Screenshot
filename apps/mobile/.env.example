# Firebase Web SDK設定（Firebaseコンソール > プロジェクトの設定 > 全般 から取得）
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# 共有ページの公開ドメイン（共有テキストの生成に使用。functions/.env.exampleのHOSTING_DOMAINと合わせる）
EXPO_PUBLIC_HOSTING_DOMAIN=https://routecard.example.com

# trueにするとFirebase Emulator Suite（`npm run functions:serve`）に接続する。
# デプロイ済みの本番Functionsを使う場合はfalse/未設定のままにする
EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false
# スマホ実機（Expo Go）からエミュレータに繋ぐ場合はPCのLAN IPを指定する（Web/シミュレータではlocalhostのままでよい）
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=localhost
